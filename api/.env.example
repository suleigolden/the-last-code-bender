DATABASE_URL=postgresql://postgres:password@localhost:5432/thelastcodebender
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
GITHUB_TOKEN=your-github-pat-with-models-read
# Fine-grained PAT: https://github.com/settings/personal-access-tokens
# Required scope: Models → Read-only (models:read)
# Optional override (default: openai/gpt-4o-mini)
GITHUB_MODEL=openai/gpt-4o-mini
FRONTEND_URL=http://localhost:3004
PORT=3000
